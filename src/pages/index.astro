---
export const prerender = true;

import { sql } from '../neon';

import Main from '../layouts/main.astro';

import Aside from '../components/aside.astro';
import ProfileCard from '../components/profile-card.astro';
import CollectionsList from '../components/collections-list.astro';
import SectionHeading from '../components/section-heading.astro';
import CtaInternal from '../components/cta-internal.astro';
import ListExternalPublishers from '../components/list-external-publishers.astro';
import GlobeAllCities from '../components/globe-all-cities';

import groupByCity from '../utils/group-by-city';
import groupByPublication from '../utils/group-by-publication';

import { getAllCollections } from '../utils/all-collections';

const { collections, articles, posts, ghosts } = await getAllCollections();

let analyticsData = [];
const period = 30;

async function fetchData(query: string) {
  try {
    const data = await sql(query);

    if (!data.length) {
      throw new Error('No data found.');
    }

    return data;
  } catch (err) {
    console.error('Failed to fetch data:', err);
    throw new Error('Could not load data.');
  }
}

try {
  analyticsData = await fetchData(`
    SELECT *
    FROM analytics
    WHERE date >= NOW() - INTERVAL '${period} days'
  `);
} catch (error) {
  analyticsData = [];
}
---

<Main title='Home' description="Paul Scanlon's site" slug='/'>
  <div class='relative flex items-center md:min-h-96'>
    <div class='relative w-full md:w-auto lg:z-10 max-w-none  lg:max-w-md'>
      <h1 class='text-5xl lg:text-6xl tracking-tight !mt-0 mb-3'>Paul Scanlon</h1>
      <h2 class='!mt-0 mb-2 text-xl font-normal text-brand-muted'>Technical Product Marketing Manager</h2>
      <p class='not-prose mb-5 text-sm text-brand-muted'>
        Currently at
        <a href='https://mastra.ai/' class='font-medium text-brand-secondary transition-colors hover:text-brand-text'>Mastra</a>
      </p>
      <div class='max-w-2xl'>
        <p class='text-sm leading-relaxed text-brand-text mb-5'>
          Developer for <strong class='text-brand-text'>20 years</strong>, now helping shape the next generation of AI-powered development tools.
        </p>
        <ul class='flex flex-wrap items-center gap-2 list-none m-0 p-0'>
          {[
            { label: 'AI', href: '/tags/ai/' },
            { label: 'TypeScript', href: '/tags/typescript/' },
            { label: 'React', href: '/tags/react/' },
            { label: 'PostgreSQL', href: '/tags/postgres/' },
          ].map(({ label, href }) => (
            <li class='m-0 p-0'>
              <a
                href={href}
                class='block rounded border border-brand-outline bg-brand-surface px-3 py-1 text-xs font-medium text-brand-muted no-underline transition-colors duration-300 hover:border-brand-muted hover:text-brand-text'
              >
                {label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>
    <div class='absolute -top-10 sm:-top-6 left-0 md:left-auto right-0 flex justify-center invisible lg:visible'>
      <GlobeAllCities
        data={groupByCity(analyticsData)}
        altitude={2.4}
        isDashboard={false}
        classNames='pointer-events-none'
      />
      <div class='absolute top-4 right-0'>
        <div class='leading-3'>
          <time class='block text-brand-muted text-xs text-right'>{`Site visits from last ${period} Days`}</time>
          <small class='block text-brand-secondary text-xs text-right'
            >Powered by
            <a href='https://neon.tech' target='_blank' rel='noopener' class='text-xs text-right'>Neon</a>
          </small>
        </div>
      </div>
    </div>
  </div>

  <SectionHeading
    title='Latest Articles'
    description='Latest articles written for external publishers.'
  />
  <CollectionsList collections={articles} slice={3} />
  <CtaInternal href='/articles/'>{`See all ${articles.length} Articles`}</CtaInternal>

  <SectionHeading
    title='Publishers'
    description='All the publications I’ve contributed to.'
  />
  <ListExternalPublishers data={groupByPublication(collections)} />
  <CtaInternal href='/dashboard/'>See more statistics</CtaInternal>

  <SectionHeading
    title='Latest Posts'
    description='Latest posts published here on my site.'
  />
  <CollectionsList collections={posts} slice={3} />
  <CtaInternal href='/posts/'>{`See all ${posts.length} Posts`}</CtaInternal>

  <SectionHeading
    title='Latest Ghostwriting'
    description='Latest articles written for clients… and the World will never know.'
  />
  <CollectionsList collections={ghosts} slice={3} />
  <CtaInternal href='/ghosts/'>{`See all ${ghosts.length} Ghosts`}</CtaInternal>

  <Aside>
    <ProfileCard />
  </Aside>
</Main>
