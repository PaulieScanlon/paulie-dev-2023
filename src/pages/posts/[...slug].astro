---
export const prerender = true;

import Main from '../../layouts/main.astro';
import TagsList from '../../components/tags-list.astro';
import Reactions from '../../components/reactions';
import TableOfContents from '../../components/table-of-contents.astro';

import { formatDate } from '../../utils/format-date';
import { createExcerpt } from '../../utils/create-excerpt';

import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('posts');

  return posts.map((post) => {
    return {
      params: {
        slug: post.slug,
      },
      props: {
        post,
      },
    };
  });
}

const {
  post,
  post: {
    slug,
    data: { title, author, date, tags, draft },
  },
} = Astro.props;

const excerpt = `${createExcerpt(post.body).substring(0, 70)}...`;
const ogImage = `${Astro.site}posts/${slug}/og.png`;

const { Content, headings } = await post.render();
---

<Main title={title} description={excerpt} slug={`/posts/${slug}/`} image={ogImage} wide={true}>
  <div class='xl:grid xl:grid-cols-[minmax(0,1fr)_14rem] xl:gap-12'>
    <div class='min-w-0'>
      {
        draft ? (
          <p class='bg-brand-tertiary rounded text-sm text-brand-background py-1 text-center'>
            Status: <span class='font-light text-inherit'>Unpublished</span>
          </p>
        ) : null
      }
      <div class='flex flex-col sm:flex-row items-start sm:items-center justify-start sm:justify-between gap-2'>
        <time class='text-xs font-light text-brand-muted'>{formatDate(date)}</time>
        <span class='text-xs font-light text-brand-muted'>{`By ${author}`}</span>
      </div>
      <h1>{title}</h1>
      <TagsList tags={tags} link={true} />
      <Content />
      <Reactions title={title} slug={`/posts/${slug}/`} />
    </div>
    <aside class='hidden xl:block'>
      <div class='sticky top-24'>
        <TableOfContents headings={headings} />
      </div>
    </aside>
  </div>
</Main>
