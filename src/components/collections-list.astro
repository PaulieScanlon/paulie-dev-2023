---
import { Image } from 'astro:assets';
import AstroImage from './astro-image.astro';

import NewLabel from './new-label';
import TagsList from './tags-list.astro';

import { formatDate } from '../utils/format-date';
import { createExcerpt } from '../utils/create-excerpt';

const { collections, slice, highlighted } = Astro.props;
---

<ul class='list-none my-8 p-0 flex flex-col gap-8'>
  {
    collections
      .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
      .slice(0, slice || collections.length)
      .filter((item) => item.data.draft !== true)
      .map((collection) => {
        const {
          slug,
          data: { base, featuredImage, logo, publication, source, title, date, tags },
        } = collection;

        const excerpt = collection.body ? createExcerpt(collection.body) : '';
        const isGhost = base === 'ghosts';
        // Blog posts use dynamic OG images, not featured images — don't show a thumbnail in the list.
        const isPost = base === 'posts';

        return (
          <li
            class={`group m-0 p-0 rounded border border-brand-outline bg-brand-surface shadow-lg transition-all duration-500 ease-in-out ${isGhost ? 'cursor-not-allowed' : 'cursor-pointer hover:-translate-y-1 hover:shadow-black/30'}`}
          >
            <div class='relative overflow-hidden rounded'>
              <NewLabel date={date} />
              <a
                href={`/${base}/${slug}/`}
                class={`flex flex-col md:flex-row gap-3 md:gap-6 items-center p-4 no-underline ${isGhost ? 'select-none pointer-events-none' : ''}`}
              >
                {featuredImage && !isPost ? (
                  <AstroImage
                    width={570}
                    height={321}
                    alt={title}
                    url={featuredImage}
                    className='!my-0 w-full md:w-1/2'
                    isEmbedded={false}
                  />
                ) : null}
                <div class='flex flex-1 min-w-0 flex-col gap-2'>
                  <span class='flex flex-col sm:flex-row gap-2 sm:items-center'>
                    {publication || source ? (
                      <>
                        <div class='flex items-center gap-2'>
                          <Image
                            width={24}
                            height={24}
                            alt={publication || source}
                            src={logo}
                            class={`m-0 ${isGhost ? 'blur-[3px]' : ''}`}
                          />
                          <small class={`text-xs text-brand-muted ${isGhost ? 'blur-[2px]' : ''}`}>
                            {publication || source}
                          </small>
                        </div>
                        <span class='hidden sm:inline-block'>&bull;</span>
                      </>
                    ) : isPost ? (
                      <>
                        <div class='flex items-center gap-2'>
                          <img src='/favicon.svg' width='24' height='24' alt='paulie.dev' class='m-0' />
                          <small class='text-xs text-brand-muted'>paulie.dev</small>
                        </div>
                        <span class='hidden sm:inline-block'>&bull;</span>
                      </>
                    ) : null}

                    <time class='text-xs font-light text-brand-muted'>{formatDate(date)}</time>
                  </span>
                  <h3 class={`m-0 text-brand-text text-xl ${isGhost ? 'blur-[3px]' : ''}`}>{title}</h3>
                  <p class={`font-light text-sm ${isGhost ? 'blur-[3px]' : ''}`}>{`${excerpt.substring(0, 120)}...`}</p>
                  <TagsList tags={tags} className='mt-2 mb-0' highlighted={highlighted} />
                </div>
              </a>
            </div>
          </li>
        );
      })
  }
</ul>
