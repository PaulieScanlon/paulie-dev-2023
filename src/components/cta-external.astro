---
const { href, className = 'my-24' } = Astro.props;
---

<div class={`flex items-center justify-center ${className}`}>
  <a
    href={href}
    target='_blank'
    rel='noopener'
    class='not-prose group inline-flex items-center gap-2 border border-brand-outline rounded bg-brand-surface text-brand-secondary font-medium text-sm no-underline px-5 py-2.5 transition-all duration-300 hover:text-brand-text hover:bg-brand-muted/10'
  >
    <slot />
    <span aria-hidden='true' class='transition-transform duration-300 group-hover:translate-x-0.5 group-hover:-translate-y-0.5'>&#8599;</span>
  </a>
</div>
